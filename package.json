{
    "name": "@airbreather/archipelago.js",
    "version": "2.2.0",
    "description": "A runtime-agnostic and zero dependency TypeScript/JavaScript library for communicating with Archipelago servers.",
    "license": "MIT",
    "type": "module",
    "author": "Zach Parks <zach@alliware.com>",
    "browserslist": [
        ">0.2%",
        "not dead"
    ],
    "exports": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">= 18.0.0"
    },
    "scripts": {
        "docs": "typedoc --options typedoc.json",
        "lint": "eslint src test",
        "prepack": "$npm_execpath run lint && bun build.ts",
        "test": "vitest --tags-filter=!integration"
    },
    "sideEffects": false,
    "homepage": "https://archipelago.js.org",
    "repository": "https://github.com/airbreather/archipelago.js.git",
    "bugs": "https://github.com/ThePhar/archipelago.js/issues",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@shipgirl/typedoc-plugin-versions": "^0.3.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/bun": "^1.3.12",
        "@typhonjs-typedoc/typedoc-theme-dmt": "^0.4.0",
        "@vitest/coverage-istanbul": "^4.1.4",
        "@vitest/eslint-plugin": "^1.6.16",
        "bun-plugin-dts": "^0.4.0",
        "eslint": "^10.2.0",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.2",
        "vitest": "^4.1.4"
    }
}

{
    "compilerOptions": {
        "rootDir": "./src/",
        "target": "ES2023",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "allowImportingTsExtensions": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "types": [
            "@types/bun"
        ]
    },
    "include": [
        "build.ts",
        "vitest.config.ts",
        "src",
        "test"
    ]
}

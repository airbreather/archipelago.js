{
    "extends": "@tsconfig/bun/tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "resolveJsonModule": true,

        // Some stricter flags (disabled by default)
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noPropertyAccessFromIndexSignature": true
    },
    "include": [
        "*.ts"
    ]
}

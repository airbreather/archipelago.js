{
	"name": "@airbreather/archipelago",
	"version": "1.0.0",
	"description": "A package that I forgot to update the description for.",
	"homepage": "https://archipelago.js.org",
	"bugs": "https://github.com/ThePhar/archipelago.js/issues",
	"repository": {
		"type": "git",
		"url": "https://github.com/airbreather/archipelago.js.git"
	},
	"license": "MIT",
	"author": "Zach Parks <zach@alliware.com>",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"./dist",
		"./src"
	],
	"scripts": {
		"docs": "typedoc --options typedoc.json",
		"prepack": "bun run --bun eslint && bun build.ts",
		"test": "vitest --tags-filter=!integration"
	},
	"browserslist": [
		">0.2%",
		"not dead"
	],
	"dependencies": {
		"@airbreather/archipelago-api": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.3.12"
	},
	"engines": {
		"node": ">= 18.0.0"
	}
}
